<!-- Briefs Dashboard — server-rendered page that displays all the briefs and includes a form to create a new one.
Requirements - Create and render at least one view using a view template and template engine. This can be a custom
template engine or a third-party engine, Weight 8%.
Use simple CSS to style the rendered views, Weight 2%.
Include a form within a rendered view that allows for interaction with your RESTful API, Weight 3%. -->

<!DOCTYPE html>

<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Brief.io | Briefs Dashboard</title>
        <link rel="stylesheet" href="/public/styles.css">
    </head>

    <body>

        <header>

            <img src="/public/images/Burgundy Placeholder Logo.png" id="logo" alt="Burgundy Placeholder Logo">

            <div id="header-inner">
            
                <h1>Briefs Dashboard</h1>

            </div>

        </header>

        <main id="main-container">

<!-- Section To Display Active Briefs -->

            <section id="briefsSection">

                <h2>Active Briefs</h2>

                <% briefs.forEach((brief) => { %>

                    <div class="brief-card">

                        <p><strong>Project Name:</strong> <%= brief.projectName %></p>
                        <p><strong>Project Type:</strong> <%= brief.projectType %></p>
                        <p><strong>Timeline:</strong> <%= brief.timeline %></p>
                        <p><strong>Brief Status:</strong> <%= brief.status %></p>

                    </div>

                <% }) %>

            </section>

<!-- Section To Submit A New Brief -->
<!-- Include a form within a rendered view that allows for interaction with your RESTful API, Weight 3%. -->

            <section id="formSection">

                <h2>Brief Submission</h2>

                <form action="/api/briefs" method="POST">

                    <input type="text" name="projectName" class="form-input" id="project-name" placeholder="Project Name - Please provide the project name." required>
                    <input type="text" name="projectType" class="form-input" id="project-type" placeholder="Project Type - Please provide the project type." required>
                    <input type="text" name="timeline" class="form-input" id="timeline" placeholder="Project Timeline - Please provide the project timeline." required>
                    <textarea name="targetAudience" class="form-input" id="target-audience" placeholder="Target Audience - Who your campaign is for. Demographics." required></textarea>
                    <input type="text" name="status" class="form-input" id="status" placeholder="Project Status - Ex: Not Started, Active, On Hold, Completed, Cancelled.">

                    <button id="submit-brief-button" type="submit">Submit Brief</button>

                </form>

            </section>

        </main>


        
    </body>

</html>